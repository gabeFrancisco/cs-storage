@rendermode InteractiveServer

<tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 border-gray-200">
    <th scope="col" class="py-1 font-thin">@Debt.Id</th>
    <th scope="col" class="py-1 font-thin">@Debt.Customer.Name</th>
    <th scope="col" class="py-1 font-thin">@Debt.Forecast.ToShortDateString()</th>
    <th scope="col" class="py-1 font-thin">R$@Debt.Value</th>
    <th scope="col" class="py-1 font-thin">@Debt.PaidDate</th>
    <th scope="col" class="py-1 font-thin">
        <button class="btn-primary font-thin py-0.5 px-3 rounded">Editar</button>
        <button class="btn-red py-0.5 font-thin px-3 rounded">Remover</button>
    </th>
</tr>