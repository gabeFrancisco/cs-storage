@using CsStorage.Application.DTOs
@rendermode InteractiveServer

<div class="w-full border border-gray-300 rounded">
    <div class="relative overflow-x-auto">
        <table class="w-full text-sm text-left rtl:text-right text-gray-600 dark:text-gray-400">
            <thead class="text-sm p-1 text-gray-700 bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
                <tr>
                    <th class="font-thin">Id</th>
                    <th class="font-thin">Descrição</th>
                    <th class="font-thin">Tipo</th>
                    <th class="font-thin">Valor</th>
                    <th class="font-thin">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach(CashRegisterDTO registerDTO in Registers){
                    <CashRow Register=registerDTO/>
                }
            </tbody>
        </table>
    </div>
</div>